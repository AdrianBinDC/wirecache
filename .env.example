# PostgreSQL connection defaults (match docker-compose.yml)
POSTGRES_DB=news
POSTGRES_USER=news
POSTGRES_PASSWORD=news
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Logging (stdout stays clean for JSON/text/voice; logs go to stderr + file)
# WIRECACHE_LOG_LEVEL=INFO
# WIRECACHE_LOG_FILE=data/wirecache.log
# Set WIRECACHE_LOG_FILE= to disable the log file
